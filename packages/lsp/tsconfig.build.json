{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "declaration": true,
        "emitDeclarationOnly": true,
        "noEmit": false,
        "outDir": "./dist",
        "rootDir": "./src",
        "paths": {
            "@wiz/config": [
                "../../../compiler/packages/config/dist/index.d.ts"
            ],
            "@wiz/language-service": [
                "../language-service/dist/index.d.ts"
            ]
        }
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "tests"
    ]
}
