{
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "strict": true,
        "skipLibCheck": true,
        "noUncheckedIndexedAccess": true,
        "exactOptionalPropertyTypes": true,
        "noImplicitOverride": true,
        "verbatimModuleSyntax": true,
        "allowImportingTsExtensions": true,
        "paths": {
            "@wiz/config": [
                "../compiler/packages/config/src/index.ts"
            ],
            "@wiz/compiler": [
                "../compiler/packages/compiler/src/index.ts"
            ],
            "@wiz/formatter": [
                "../linter/packages/formatter/src/index.ts"
            ],
            "@wiz/linter": [
                "../linter/packages/linter/src/index.ts"
            ],
            "@wiz/language-service": [
                "./packages/language-service/src/index.ts"
            ],
            "@wiz/lsp": [
                "./packages/lsp/src/index.ts"
            ],
            "@wiz/types/*": [
                "../types/wiz/types/*"
            ]
        },
        "noEmit": true,
        "types": [
            "bun-types"
        ]
    },
    "include": [
        "packages/**/*.ts"
    ],
    "exclude": [
        "**/dist",
        "**/node_modules"
    ]
}
