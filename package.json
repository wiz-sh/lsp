{
    "name": "@wiz-sh/lsp-workspace",
    "private": true,
    "license": "MIT",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "bun run --cwd packages/language-service build && bun run --cwd packages/lsp build",
        "lint": "biome lint .",
        "lint:fix": "biome lint --write .",
        "format": "biome format --write .",
        "format:check": "biome format .",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "test:unit": "bun test packages",
        "test:coverage": "bun test --coverage",
        "cloc": "bun x --package cloc cloc packages/*/src --include-ext=ts,json",
        "check": "biome check . && bun run typecheck && bun test",
        "check:fix": "biome check --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.2.0",
        "@wiz-sh/compiler": "file:../compiler/packages/compiler",
        "@wiz-sh/config": "file:../compiler/packages/config",
        "@wiz-sh/formatter": "file:../linter/packages/formatter",
        "@wiz-sh/linter": "file:../linter/packages/linter",
        "bun-types": "^1.2.19",
        "typescript": "^5.9.2"
    },
    "overrides": {
        "@wiz-sh/compiler": "file:../compiler/packages/compiler",
        "@wiz-sh/config": "file:../compiler/packages/config",
        "@wiz-sh/formatter": "file:../linter/packages/formatter",
        "@wiz-sh/linter": "file:../linter/packages/linter"
    },
    "packageManager": "bun@1.3.14"
}
